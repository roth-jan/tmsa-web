generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & BERECHTIGUNGEN
// ============================================================

model Benutzer {
  id               String    @id @default(uuid())
  benutzername     String    @unique
  passwortHash     String
  vorname          String
  nachname         String
  email            String?
  aktiv            Boolean   @default(true)
  niederlassungId  String?
  niederlassung    Niederlassung? @relation(fields: [niederlassungId], references: [id])
  rollen           BenutzerRolle[]
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
}

model Rolle {
  id          String    @id @default(uuid())
  name        String    @unique
  beschreibung String?
  benutzer    BenutzerRolle[]
  rechte      RolleRecht[]
  erstelltAm  DateTime  @default(now())
}

model BenutzerRolle {
  benutzerId String
  rolleId    String
  benutzer   Benutzer @relation(fields: [benutzerId], references: [id])
  rolle      Rolle    @relation(fields: [rolleId], references: [id])
  @@id([benutzerId, rolleId])
}

model Recht {
  id     String @id @default(uuid())
  modul  String
  aktion String
  rollen RolleRecht[]
  @@unique([modul, aktion])
}

model RolleRecht {
  rolleId String
  rechtId String
  rolle   Rolle @relation(fields: [rolleId], references: [id])
  recht   Recht @relation(fields: [rechtId], references: [id])
  @@id([rolleId, rechtId])
}

// ============================================================
// STAMMDATEN
// ============================================================

model Niederlassung {
  id               String    @id @default(uuid())
  name             String
  kurzbezeichnung  String
  adresse          String?
  plz              String?
  ort              String?
  aktiv            Boolean   @default(true)
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?

  benutzer         Benutzer[]
  transportUnternehmer TransportUnternehmer[]
  dispoOrte        DispoOrt[]
  dispoRegeln      DispoRegel[]
  avise            Avis[]
  touren           Tour[]
  abfahrten        Abfahrt[]
  sendungen        Sendung[]
  tuAbrechnungen   TuAbrechnung[]
  umschlagPunkte   UmschlagPunkt[]
  forecasts        Forecast[]
}

model Oem {
  id               String    @id @default(uuid())
  name             String
  kurzbezeichnung  String
  ediKennung       String?
  aktiv            Boolean   @default(true)
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?

  werke            Werk[]
  routen           Route[]
  sendungen        Sendung[]
  forecasts        Forecast[]
}

model Werk {
  id          String    @id @default(uuid())
  name        String
  werkscode   String?
  adresse     String?
  plz         String?
  ort         String?
  aktiv       Boolean   @default(true)
  oemId       String
  oem         Oem       @relation(fields: [oemId], references: [id])
  erstelltAm  DateTime  @default(now())
  geaendertAm DateTime  @updatedAt
  geloeschtAm DateTime?

  abladestellen Abladestelle[]
  dispoOrte     DispoOrt[]
  avise         Avis[]
  sendungen     Sendung[]
  forecasts     Forecast[]
}

model Lieferant {
  id                String    @id @default(uuid())
  name              String
  lieferantennummer String?
  adresse           String?
  plz               String?
  ort               String?
  land              String?
  aktiv             Boolean   @default(true)
  erstelltAm        DateTime  @default(now())
  geaendertAm       DateTime  @updatedAt
  geloeschtAm       DateTime?

  avise             Avis[]
  sendungen         Sendung[]
}

model Abladestelle {
  id          String    @id @default(uuid())
  name        String
  werkId      String
  werk        Werk      @relation(fields: [werkId], references: [id])
  entladeZone String?
  aktiv       Boolean   @default(true)
  erstelltAm  DateTime  @default(now())
  geaendertAm DateTime  @updatedAt
  geloeschtAm DateTime?

  avise       Avis[]
  sendungen   Sendung[]
}

model TransportUnternehmer {
  id               String    @id @default(uuid())
  name             String
  kurzbezeichnung  String
  adresse          String?
  plz              String?
  ort              String?
  niederlassungId  String
  niederlassung    Niederlassung @relation(fields: [niederlassungId], references: [id])
  aktiv            Boolean   @default(true)
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?

  fahrzeuge        Kfz[]
  konditionen      Kondition[]
  touren           Tour[]
  abfahrten        Abfahrt[]
  tuAbrechnungen   TuAbrechnung[]
  streckenabschnitte Streckenabschnitt[]
}

model Kfz {
  id                 String    @id @default(uuid())
  kennzeichen        String
  transportUnternehmerId String
  transportUnternehmer  TransportUnternehmer @relation(fields: [transportUnternehmerId], references: [id])
  fabrikat           String?
  lkwTyp             String?
  maxLdm             Decimal?  @db.Decimal(10, 2)
  maxGewicht         Decimal?  @db.Decimal(10, 2)
  schadstoffklasse   String?
  aktiv              Boolean   @default(true)
  erstelltAm         DateTime  @default(now())
  geaendertAm        DateTime  @updatedAt
  geloeschtAm        DateTime?

  touren             Tour[]
  abfahrten          Abfahrt[]
  streckenabschnitte Streckenabschnitt[]
}

model Route {
  id             String    @id @default(uuid())
  routennummer   String
  oemId          String
  oem            Oem       @relation(fields: [oemId], references: [id])
  beschreibung   String?
  kilometerLast  Decimal?  @db.Decimal(10, 2)
  kilometerLeer  Decimal?  @db.Decimal(10, 2)
  kilometerMaut  Decimal?  @db.Decimal(10, 2)
  aktiv          Boolean   @default(true)
  erstelltAm     DateTime  @default(now())
  geaendertAm    DateTime  @updatedAt
  geloeschtAm    DateTime?

  konditionen    Kondition[]
  avise          Avis[]
  touren         Tour[]
  abfahrten      Abfahrt[]
  streckenabschnitte Streckenabschnitt[]
}

model Kondition {
  id                    String    @id @default(uuid())
  name                  String
  transportUnternehmerId String
  transportUnternehmer  TransportUnternehmer @relation(fields: [transportUnternehmerId], references: [id])
  routeId               String?
  route                 Route?    @relation(fields: [routeId], references: [id])
  tourFaktor            Decimal?  @db.Decimal(10, 4)
  stoppFaktor           Decimal?  @db.Decimal(10, 4)
  tagFaktor             Decimal?  @db.Decimal(10, 4)
  lastKmFaktor          Decimal?  @db.Decimal(10, 4)
  leerKmFaktor          Decimal?  @db.Decimal(10, 4)
  mautKmFaktor          Decimal?  @db.Decimal(10, 4)
  maximalFrachtProTour  Decimal?  @db.Decimal(10, 2)
  maximalFrachtProTag   Decimal?  @db.Decimal(10, 2)
  gueltigVon            DateTime
  gueltigBis            DateTime?
  erstelltAm            DateTime  @default(now())
  geaendertAm           DateTime  @updatedAt
  geloeschtAm           DateTime?

  touren                    Tour[]
  tuAbrechnungsPositionen   TuAbrechnungsPosition[]
  streckenabschnitte        Streckenabschnitt[]
}

// ============================================================
// DISPOSITION
// ============================================================

model DispoOrt {
  id               String    @id @default(uuid())
  bezeichnung      String
  plz              String?
  ort              String?
  land             String?   @default("DE")
  sortierung       Int       @default(0)
  werkId           String?
  werk             Werk?     @relation(fields: [werkId], references: [id])
  niederlassungId  String
  niederlassung    Niederlassung @relation(fields: [niederlassungId], references: [id])
  aktiv            Boolean   @default(true)
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?
}

model DispoRegel {
  id               String    @id @default(uuid())
  bezeichnung      String
  regeltyp         String
  prioritaet       Int       @default(0)
  bedingung        String?
  aktion           String?
  istAktiv         Boolean   @default(true)
  niederlassungId  String
  niederlassung    Niederlassung @relation(fields: [niederlassungId], references: [id])
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?
}

model Avis {
  id               String    @id @default(uuid())
  avisNummer       String    @unique
  ladeDatum        DateTime
  status           String    @default("offen") // offen, disponiert, abgeschlossen, storniert
  bemerkung        String?
  lieferantId      String
  lieferant        Lieferant @relation(fields: [lieferantId], references: [id])
  werkId           String
  werk             Werk      @relation(fields: [werkId], references: [id])
  abladestelleId   String?
  abladestelle     Abladestelle? @relation(fields: [abladestelleId], references: [id])
  niederlassungId  String
  niederlassung    Niederlassung @relation(fields: [niederlassungId], references: [id])
  routeId          String?
  route            Route?    @relation(fields: [routeId], references: [id])
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?

  artikelzeilen    Artikelzeile[]
}

model Artikelzeile {
  id                  String    @id @default(uuid())
  artikelBeschreibung String
  menge               Decimal   @db.Decimal(10, 2)
  masseinheit         String    @default("ST") // ST, KG, PAL
  gewicht             Decimal?  @db.Decimal(10, 2)
  volumen             Decimal?  @db.Decimal(10, 4)
  gutArt              String    @default("VOLLGUT") // VOLLGUT, LEERGUT
  status              Int       @default(0) // 0=offen, 1=disponiert, 2=split, 3=storniert
  avisId              String
  avis                Avis      @relation(fields: [avisId], references: [id], onDelete: Cascade)
  tourId              String?
  tour                Tour?     @relation(fields: [tourId], references: [id])
  erstelltAm          DateTime  @default(now())
  geaendertAm         DateTime  @updatedAt
}

model Tour {
  id                      String    @id @default(uuid())
  tourNummer              String    @unique
  tourDatum               DateTime
  status                  String    @default("offen") // offen, disponiert, abgefahren, abgeschlossen
  kfzId                   String?
  kfz                     Kfz?      @relation(fields: [kfzId], references: [id])
  transportUnternehmerId  String?
  transportUnternehmer    TransportUnternehmer? @relation(fields: [transportUnternehmerId], references: [id])
  konditionId             String?
  kondition               Kondition? @relation(fields: [konditionId], references: [id])
  routeId                 String?
  route                   Route?    @relation(fields: [routeId], references: [id])
  leerKilometer           Decimal?  @db.Decimal(10, 2)
  lastKilometer           Decimal?  @db.Decimal(10, 2)
  mautKilometer           Decimal?  @db.Decimal(10, 2)
  kostenKondition         Decimal?  @db.Decimal(10, 2)
  kostenManuell           Decimal?  @db.Decimal(10, 2)
  bemerkungIntern         String?
  bemerkungExtern         String?
  // Nacharbeit-Felder
  quittung                Boolean   @default(false)
  quittungDatum           DateTime?
  istLeerfahrt            Boolean   @default(false)
  abrechnungsStopp        Boolean   @default(false)
  abrechnungsStatus       Int       @default(0) // 0=offen, 1=bewertet, 2=freigegeben, 3=erzeugt
  bemerkungAbrechnung     String?
  istGebrochen            Boolean   @default(false)
  niederlassungId         String
  niederlassung           Niederlassung @relation(fields: [niederlassungId], references: [id])
  erstelltAm              DateTime  @default(now())
  geaendertAm             DateTime  @updatedAt
  geloeschtAm             DateTime?

  artikelzeilen           Artikelzeile[]
  abfahrten               Abfahrt[]
  tuAbrechnungsPositionen TuAbrechnungsPosition[]
  streckenabschnitte      Streckenabschnitt[]
}

// ============================================================
// OPERATIV
// ============================================================

model Abfahrt {
  id                      String    @id @default(uuid())
  abfahrtNummer           String    @unique
  datum                   DateTime
  status                  String    @default("offen") // offen, abgefahren, abgeschlossen
  abrechnungsStatus       Int       @default(0) // 0=offen, 1=bewertet, 2=freigegeben, 3=erzeugt
  kfzId                   String?
  kfz                     Kfz?      @relation(fields: [kfzId], references: [id])
  transportUnternehmerId  String?
  transportUnternehmer    TransportUnternehmer? @relation(fields: [transportUnternehmerId], references: [id])
  routeId                 String?
  route                   Route?    @relation(fields: [routeId], references: [id])
  tourId                  String?
  tour                    Tour?     @relation(fields: [tourId], references: [id])
  niederlassungId         String
  niederlassung           Niederlassung @relation(fields: [niederlassungId], references: [id])
  bemerkung               String?
  erstelltAm              DateTime  @default(now())
  geaendertAm             DateTime  @updatedAt
  geloeschtAm             DateTime?

  borderos                Bordero[]
}

model Bordero {
  id              String    @id @default(uuid())
  borderoNummer   String    @unique
  abfahrtId       String
  abfahrt         Abfahrt   @relation(fields: [abfahrtId], references: [id])
  gewicht         Decimal?  @db.Decimal(10, 2)
  lademeter       Decimal?  @db.Decimal(10, 2)
  status          String    @default("offen") // offen, borderiert, abgeschlossen
  bemerkung       String?
  erstelltAm      DateTime  @default(now())
  geaendertAm     DateTime  @updatedAt

  sendungen       Sendung[]
}

model Sendung {
  id                  String    @id @default(uuid())
  sendungNummer       String    @unique
  datum               DateTime
  status              Int       @default(0) // 0=offen, 1=borderiert, 2=storniert
  richtungsArt        String    @default("WE") // WE, WA, 3G
  borderoId           String?
  bordero             Bordero?  @relation(fields: [borderoId], references: [id])
  oemId               String?
  oem                 Oem?      @relation(fields: [oemId], references: [id])
  werkId              String?
  werk                Werk?     @relation(fields: [werkId], references: [id])
  lieferantId         String?
  lieferant           Lieferant? @relation(fields: [lieferantId], references: [id])
  abladestelleId      String?
  abladestelle        Abladestelle? @relation(fields: [abladestelleId], references: [id])
  niederlassungId     String
  niederlassung       Niederlassung @relation(fields: [niederlassungId], references: [id])
  gewicht             Decimal?  @db.Decimal(10, 2)
  lademeter           Decimal?  @db.Decimal(10, 2)
  bemerkungExtern     String?
  istSonderfahrt      Boolean   @default(false)
  erstelltAm          DateTime  @default(now())
  geaendertAm         DateTime  @updatedAt
  geloeschtAm         DateTime?
}

// ============================================================
// GEBROCHENE VERKEHRE
// ============================================================

model UmschlagPunkt {
  id               String    @id @default(uuid())
  name             String
  kurzbezeichnung  String
  adresse          String?
  plz              String?
  ort              String?
  niederlassungId  String
  niederlassung    Niederlassung @relation(fields: [niederlassungId], references: [id])
  aktiv            Boolean   @default(true)
  erstelltAm       DateTime  @default(now())
  geaendertAm      DateTime  @updatedAt
  geloeschtAm      DateTime?

  streckenabschnitte Streckenabschnitt[]
}

model Streckenabschnitt {
  id                      String    @id @default(uuid())
  tourId                  String
  tour                    Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
  reihenfolge             Int
  typ                     String                    // VL, HL, NL
  vonBeschreibung         String
  nachBeschreibung        String
  umschlagPunktId         String?
  umschlagPunkt           UmschlagPunkt? @relation(fields: [umschlagPunktId], references: [id])
  routeId                 String?
  route                   Route?    @relation(fields: [routeId], references: [id])
  transportUnternehmerId  String?
  transportUnternehmer    TransportUnternehmer? @relation(fields: [transportUnternehmerId], references: [id])
  kfzId                   String?
  kfz                     Kfz?      @relation(fields: [kfzId], references: [id])
  konditionId             String?
  kondition               Kondition? @relation(fields: [konditionId], references: [id])
  lastKilometer           Decimal?  @db.Decimal(10, 2)
  leerKilometer           Decimal?  @db.Decimal(10, 2)
  mautKilometer           Decimal?  @db.Decimal(10, 2)
  kostenKondition         Decimal?  @db.Decimal(10, 2)
  status                  String    @default("offen") // offen, disponiert, abgefahren, abgeschlossen
  erstelltAm              DateTime  @default(now())
  geaendertAm             DateTime  @updatedAt

  @@unique([tourId, reihenfolge])
}

// ============================================================
// FORECAST (Mengenprognose)
// ============================================================

model Forecast {
  id              String           @id @default(uuid())
  bezeichnung     String
  oemId           String
  oem             Oem              @relation(fields: [oemId], references: [id])
  werkId          String
  werk            Werk             @relation(fields: [werkId], references: [id])
  gueltigVon      DateTime
  gueltigBis      DateTime
  status          String           @default("entwurf") // entwurf, aktiv, abgeschlossen
  niederlassungId String
  niederlassung   Niederlassung    @relation(fields: [niederlassungId], references: [id])
  erstelltAm      DateTime         @default(now())
  geaendertAm     DateTime         @updatedAt
  geloeschtAm     DateTime?
  details         ForecastDetail[]
}

model ForecastDetail {
  id             String   @id @default(uuid())
  forecastId     String
  forecast       Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)
  kalenderwoche  Int
  jahr           Int
  menge          Int
  gewicht        Int      @default(0)
  erstelltAm     DateTime @default(now())
}

// ============================================================
// AUDIT & EDI-IMPORT
// ============================================================

model AuditLog {
  id            String   @id @default(uuid())
  modell        String
  aktion        String   // create, update, delete
  entitaetId    String
  benutzerId    String?
  benutzerName  String?
  zeitpunkt     DateTime @default(now())
  alterWert     Json?
  neuerWert     Json?

  @@index([modell, entitaetId])
  @@index([benutzerId])
  @@index([zeitpunkt])
}

model EdiImport {
  id            String   @id @default(uuid())
  format        String   // VDA4913, VDA4927, DESADV, IFCSUM
  dateiname     String?
  status        String   @default("success") // success, error, partial
  ergebnis      Json?
  rohdaten      String?
  benutzerId    String?
  benutzerName  String?
  erstelltAm    DateTime @default(now())

  @@index([format])
  @@index([erstelltAm])
}

// ============================================================
// ABRECHNUNG
// ============================================================

model TuAbrechnung {
  id                      String    @id @default(uuid())
  belegnummer             String    @unique
  buchungsjahr            Int
  zeitraumVon             DateTime
  zeitraumBis             DateTime
  transportUnternehmerId  String
  transportUnternehmer    TransportUnternehmer @relation(fields: [transportUnternehmerId], references: [id])
  niederlassungId         String
  niederlassung           Niederlassung @relation(fields: [niederlassungId], references: [id])
  anzahlPositionen        Int       @default(0)
  gesamtbetrag            Decimal   @default(0) @db.Decimal(10, 2)
  status                  String    @default("offen") // offen, erzeugt, storniert
  bemerkung               String?
  erstelltAm              DateTime  @default(now())
  geaendertAm             DateTime  @updatedAt
  geloeschtAm             DateTime?

  positionen              TuAbrechnungsPosition[]
}

model TuAbrechnungsPosition {
  id                String    @id @default(uuid())
  tuAbrechnungId    String
  tuAbrechnung      TuAbrechnung @relation(fields: [tuAbrechnungId], references: [id], onDelete: Cascade)
  tourId            String
  tour              Tour      @relation(fields: [tourId], references: [id])
  tourNummer        String
  tourDatum         DateTime
  konditionId       String?
  kondition         Kondition? @relation(fields: [konditionId], references: [id])
  konditionName     String?
  tourKosten        Decimal   @default(0) @db.Decimal(10, 2)
  stoppKosten       Decimal   @default(0) @db.Decimal(10, 2)
  tagKosten         Decimal   @default(0) @db.Decimal(10, 2)
  lastKmKosten      Decimal   @default(0) @db.Decimal(10, 2)
  leerKmKosten      Decimal   @default(0) @db.Decimal(10, 2)
  mautKmKosten      Decimal   @default(0) @db.Decimal(10, 2)
  gesamtKosten      Decimal   @default(0) @db.Decimal(10, 2)
  lastKilometer     Decimal?  @db.Decimal(10, 2)
  leerKilometer     Decimal?  @db.Decimal(10, 2)
  mautKilometer     Decimal?  @db.Decimal(10, 2)
  istManuell        Boolean   @default(false)
  bemerkung         String?
  erstelltAm        DateTime  @default(now())
}
